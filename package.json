{
  "name": "uni-notice-board",
  "version": "1.0.0",
  "description": "University Digital Notice Board",
  "scripts": {
    "start": "parcel src/*.html",
    "build": "parcel build src/*.html --dist-dir dist",
    "lint:html": "htmlhint src/*.html",
    "lint:css": "stylelint \"styles/*.css\""
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "parcel": "^2.12.0",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0"
  }
}
